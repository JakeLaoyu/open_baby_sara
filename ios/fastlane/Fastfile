default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # API Key'i projeye otomatik olarak bagla
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_#{ENV['APP_STORE_CONNECT_KEY_ID']}.p8",
      in_house: false # TestFlight (Enterprise degil)
    )

    # Sertifika ve Provisioning profillerini yonet (Basitlik icin match yerine cert/sigh kullanabilir veya otomatik Xcode imzalama)
    # Eger Xcode uzerinde "Automatically manage signing" aciksa, get_certificates/get_provisioning_profile adimlarina gerek kalmayabilir.
    # Burada Apple'in yeni otomatik imzalama ozelligini kullanmak daha stabil bir baslangictir.
    
    # Pods (eger varsa) yukle
    cocoapods(
      clean_install: true,
      use_bundle_exec: false
    ) if File.exist?("../Podfile")

    # Uygulamayi derle
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      clean: true,
      export_method: "app-store" # TestFlight icin app-store kullanilir
    )

    # TestFlight'a yukle
    upload_to_testflight(
      skip_waiting_for_build_processing: true # CI surecini kisaltmak icin bekleme
    )
  end
end
