<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sleep_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sleep_widget_background"
    android:padding="14dp"
    android:gravity="start">

    <!-- Başlık: 🌙 + "Sleep" etiketi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_sleep_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep"
            android:textColor="#3D3D3D"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Boşluk doldurucu -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Timer (sadece çalışırken görünür) -->
    <Chronometer
        android:id="@+id/chrono_sleep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#7C6CF7"
        android:textSize="26sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- "Tap to pause" ipucu (sadece çalışırken) -->
    <TextView
        android:id="@+id/tv_stop_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to pause"
        android:textColor="#888888"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- Son uyku süresi (çalışmıyorken, veri varsa) -->
    <TextView
        android:id="@+id/tv_last_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#3D3D3D"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- "Last sleep" etiketi -->
    <TextView
        android:id="@+id/tv_last_sleep_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last sleep"
        android:textColor="#888888"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- "Tap to start" (hiç veri yoksa) -->
    <TextView
        android:id="@+id/tv_start_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to start"
        android:textColor="#888888"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Boşluk doldurucu -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
